[Unit]
Description=Cuerposonoro Jetson - Body-to-sound art installation
After=network.target sound.target

[Service]
Type=simple
User=jetson
WorkingDirectory=/home/jetson/cuerposonoro-jetson
ExecStart=/usr/bin/python3 /home/jetson/cuerposonoro-jetson/main.py
Environment=PYTHONUNBUFFERED=1
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
