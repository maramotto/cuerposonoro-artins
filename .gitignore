# =============================================================================
# cuerposonoro-jetson .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python
build/
dist/
*.egg-info/
*.egg
.eggs
.claude/

# Virtual environments
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Models and weights (downloaded/generated by setup_jetson.sh)
# -----------------------------------------------------------------------------

# YOLOv8 PyTorch weights
*.pt
*.pth

# TensorRT engine (generated on Jetson at first run)
*.engine
*.trt

# ONNX intermediate (generated during TRT export)
*.onnx

# -----------------------------------------------------------------------------
# Soundfonts (downloaded by setup_jetson.sh)
# -----------------------------------------------------------------------------
*.sf2
*.sf3

# -----------------------------------------------------------------------------
# Audio and video
# -----------------------------------------------------------------------------
*.wav
*.mp3
*.flac
*.ogg
*.mp4
*.avi
*.mov

# -----------------------------------------------------------------------------
# Logs and session data
# -----------------------------------------------------------------------------
logs/
*.log
*.csv

# -----------------------------------------------------------------------------
# IDE and editors
# -----------------------------------------------------------------------------

# PyCharm
.idea/
*.iml

# VS Code
.vscode/

# macOS
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# Thumbnails
._*

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.secret
secrets/

# -----------------------------------------------------------------------------
# pytest
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# -----------------------------------------------------------------------------
# Jupyter (just in case)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.swp
*.swo
*~